#!/usr/bin/env bash
# =========================================================
# build-bin — Unified Go Builder for SSH Forge Suite
# =========================================================

set -Eeuo pipefail
IFS=$'\n\t'

# ==============================
# COLORS
# ==============================
GREEN="\033[1;32m"
YELLOW="\033[1;33m"
RED="\033[1;31m"
BLUE="\033[1;34m"
CYAN="\033[1;36m"
MAGENTA="\033[1;35m"
BOLD="\033[1m"
NC="\033[0m"

# ==============================
# CONFIG
# ==============================
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
SRC_DIR="$PROJECT_ROOT/src"
BIN_DIR="$PROJECT_ROOT/bin"

rm -rf "$BIN_DIR"
mkdir -p "$BIN_DIR"

# output binary name → source file
declare -A APPS=(
    ["ssh-forge"]="main.go"
    ["scpx"]="scpx.go"
    ["sf-key"]="sf-key.go"
    ["sf-git-auth"]="sf-git-auth.go"
    ["sf-cpy"]="sf-cpy.go"
    ["sf-reset"]="sf-reset.go"
)

# ==============================
# DEPENDENCY CHECK
# ==============================
need() {
    command -v "$1" >/dev/null 2>&1 || {
        echo -e "${RED}❌ $1 not installed.${NC}"
        exit 1
    }
}

need go

# ==============================
# DETECT ARCH
# ==============================
ARCH=$(go env GOARCH)
echo -e "${BLUE}${BOLD}🚀 Host Architecture: $ARCH${NC}"

# ==============================
# GO CACHE CLEAN + MODULE INIT
# ==============================
echo -e "${CYAN}🧹 Cleaning Go build cache...${NC}"
go clean -cache

echo -e "${CYAN}🗑  Removing old go.mod / go.sum...${NC}"
rm -f "$SRC_DIR/go.mod" "$SRC_DIR/go.sum"

echo -e "${BLUE}⚙️  Initializing Go module...${NC}"
(cd "$SRC_DIR" && go mod init github.com/dev-boffin-io/ssh-forge && go mod tidy)

echo -e "\n${YELLOW}${BOLD}🔨 Starting unified build...${NC}"
echo -e "${CYAN}📦 Flags: -trimpath -ldflags='-s -w' CGO_ENABLED=0${NC}"
echo -e "${MAGENTA}--------------------------------------${NC}"

# ==============================
# BUILD LOOP
# ==============================
FAILED=0

for APP in "${!APPS[@]}"; do
    SRC="$SRC_DIR/${APPS[$APP]}"
    OUTPUT="$BIN_DIR/$APP"

    echo -e "\n${BLUE}${BOLD}🔨 Building $APP from src/${APPS[$APP]}...${NC}"

    if [[ ! -f "$SRC" ]]; then
        echo -e "${YELLOW}⚠  Skipping $APP — ${APPS[$APP]} not found in $SRC_DIR${NC}"
        FAILED=$((FAILED + 1))
        continue
    fi

    if CGO_ENABLED=0 go build -trimpath -ldflags="-s -w" -o "$OUTPUT" "$SRC"; then
        chmod +x "$OUTPUT"
        SIZE=$(du -h "$OUTPUT" | cut -f1)
        BYTES=$(wc -c < "$OUTPUT")
        echo -e "${GREEN}✅ $APP built successfully${NC}"
        echo -e "   📦 Location : ${BOLD}$OUTPUT${NC}"
        echo -e "   📊 Size     : $SIZE ($BYTES bytes)"
    else
        echo -e "${RED}❌ Build failed: $APP${NC}"
        FAILED=$((FAILED + 1))
    fi
done

echo -e "\n${MAGENTA}--------------------------------------${NC}"

if [[ "$FAILED" -gt 0 ]]; then
    echo -e "${RED}❌ $FAILED binary/binaries failed to build.${NC}"
    exit 1
fi

echo -e "${GREEN}${BOLD}⚙️  All bin/* binaries built successfully! 🆗${NC}"
