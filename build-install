#!/usr/bin/env bash
# =========================================================
# build-install — Build all SSH Forge binaries
# =========================================================

set -Eeuo pipefail
IFS=$'\n\t'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

GREEN="\033[1;32m"
YELLOW="\033[1;33m"
RED="\033[1;31m"
BLUE="\033[1;34m"
BOLD="\033[1m"
NC="\033[0m"

DRY_RUN=0
CLI_ONLY=0

for arg in "$@"; do
    case "$arg" in
        --dry-run) DRY_RUN=1 ;;
        --cli)     CLI_ONLY=1 ;;
    esac
done

if [[ "$DRY_RUN" -eq 1 ]]; then
    echo -e "${YELLOW}${BOLD}[DRY RUN] — no files will be built${NC}"
    echo -e "Would build: ssh-forge-dev (installer)"
    echo -e "Would build: ssh-forge sf-key sf-cpy sf-reset sf-git-auth scpx"
    [[ "$CLI_ONLY" -eq 0 ]] && echo -e "Would build: ssh-forge-gui (GUI)"
    exit 0
fi

echo -e "${BLUE}${BOLD}=== Building ssh-forge-dev installer ===${NC}"
bash "$SCRIPT_DIR/build/build-init"

echo -e "\n${BLUE}${BOLD}=== Building CLI binaries ===${NC}"
bash "$SCRIPT_DIR/build/build-bin"

if [[ "$CLI_ONLY" -eq 0 ]] && [[ -f "$SCRIPT_DIR/build/build-gui" ]]; then
    echo -e "\n${BLUE}${BOLD}=== Building GUI ===${NC}"
    bash "$SCRIPT_DIR/build/build-gui"
fi

echo -e "\n${GREEN}${BOLD}✅ All done. Run './ssh-forge-dev install' to install.${NC}"
